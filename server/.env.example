PORT=5000

# Primary URI (Atlas SRV format)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/restaurant_db?retryWrites=true&w=majority

# If you get "querySrv ECONNREFUSED", paste Atlas "Standard connection string" here:
# MONGODB_URI_DIRECT=mongodb://USER:PASSWORD@cluster0-shard-00-00.xxxxx.mongodb.net:27017,.../restaurant_db?ssl=true&authSource=admin

JWT_SECRET=change-this-to-a-long-random-string
ADMIN_EMAIL=admin@savoryhaven.com
ADMIN_PASSWORD=admin123
